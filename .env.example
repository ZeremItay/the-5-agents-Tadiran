# ==========================================================
# .env.example — תבנית משתני הסביבה של הפרויקט
# ----------------------------------------------------------
# הוראות: העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
#   cp .env.example .env
# הקובץ .env מוגן ע"י .gitignore ולעולם לא יעלה ל-Git.
# כאן שומרים רק שמות מפתחות (placeholders) — בלי ערכים אמיתיים!
# ==========================================================

# ----- ראובן (מנכ"ל) / Claude — המוח של הסוכנים -----
ANTHROPIC_API_KEY=

# ----- חן (חוקרת) — חיפוש ומחקר באינטרנט -----
# בחר/י ספק חיפוש לפי הצורך:
# TAVILY_API_KEY=
# PERPLEXITY_API_KEY=

# ----- יובל (מעצב תמונות) — יצירת תמונות -----
# Gemini / Nano Banana ליצירת ועריכת תמונות:
# GEMINI_API_KEY=

# ----- אינטגרציות / פרסום תוכן (אופציונלי) -----
# Airtable — מאגר/ניהול תוכן:
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
